### ─── AUTH ──────────────────────────────────────────────

### 1. Register Owner
POST {{baseUrl}}/api/auth/register/owner
Content-Type: application/json

{
  "name": "Admin Owner",
  "email": "owner@ironcore.gym",
  "password": "ironcore123",
  "role": "owner"
}

### 2. Login Owner
POST {{baseUrl}}/api/auth/login/owner
Content-Type: application/json

{
  "email": "owner@ironcore.gym",
  "password": "admin123"
}

### 3. Register Staff (requires owner token)
POST {{baseUrl}}/api/auth/register/staff
Content-Type: application/json
Authorization: Bearer {{ownerToken}}

{
  "name": "Bianca Cruz",
  "username": "bianca_cruz",
  "password": "staff123",
  "role": "staff"
}

### 4. Login Staff
POST {{baseUrl}}/api/auth/login/staff
Content-Type: application/json

{
  "username": "bianca_cruz",
  "password": "staff123"
}

### 5. Get Current User
GET {{baseUrl}}/api/auth/me
Authorization: Bearer {{ownerToken}}

### ─── WALK-IN ─────────────────────────────────────────

### 6. Register Walk-in (requires staff or owner token)
POST {{baseUrl}}/api/walkin/register
Content-Type: application/json
Authorization: Bearer {{staffToken}}

{
  "name": "Jose Rizal",
  "phone": "09171234567",
  "passType": "student"
}

### 7. Get Today's Walk-ins + Revenue Summary
GET {{baseUrl}}/api/walkin/today
Authorization: Bearer {{staffToken}}

### 8. Staff Checkout Walk-in
PATCH {{baseUrl}}/api/walkin/checkout
Content-Type: application/json
Authorization: Bearer {{staffToken}}

{
  "walkId": "WALK-002"
}

### 9. Kiosk Self Checkout (no token needed — public)
POST {{baseUrl}}/api/walkin/kiosk-checkout
Content-Type: application/json

{
  "walkId": "WALK-002"
}

//----------------------------------------------------------

### 10. Get all members
GET {{baseUrl}}/api/members
Authorization: Bearer {{ownerToken}}

### 11. Create a member
POST {{baseUrl}}/api/members
Content-Type: application/json
Authorization: Bearer {{ownerToken}}

{
  "name": "Juan Dela Cruz",
  "email": "juan@ironcore.gym",
  "plan": "Monthly",
  "status": "active",
  "expiresAt": "2026-12-31"
}

### 12. Get member by GYM-ID
GET {{baseUrl}}/api/members/GYM-1001
Authorization: Bearer {{ownerToken}}

### 13. Update member
PATCH {{baseUrl}}/api/members/GYM-1001
Content-Type: application/json
Authorization: Bearer {{ownerToken}}

{
  "plan": "Annual",
  "status": "active",
  "expiresAt": "2027-12-31"
}


### Get Gym Info (public)
GET http://localhost:5000/api/auth/gym-info

### Update Gym Info
PUT http://localhost:5000/api/auth/update-gym
Authorization: Bearer {{ownerToken}}
Content-Type: application/json

{
  "gymName": "IronCore Fitness",
  "gymAddress": "San Jose, Antique, Philippines"
}

### Upload Logo
POST http://localhost:5000/api/auth/upload-logo
Authorization: Bearer {{ownerToken}}
Content-Type: multipart/form-data; boundary=boundary

--boundary
Content-Disposition: form-data; name="logo"; filename="logo.png"
Content-Type: image/png

< ./logo.png
--boundary--

### Delete Logo
DELETE http://localhost:5000/api/auth/delete-logo
Authorization: Bearer {{ownerToken}}
